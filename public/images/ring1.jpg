<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 300 300" width="300" height="300">
  <defs>
    <linearGradient id="goldGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#f4e8c1;stop-opacity:1" />
      <stop offset="50%" style="stop-color:#d4af37;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#a68d28;stop-opacity:1" />
    </linearGradient>
  </defs>
  <rect width="300" height="300" fill="#fafaf8"/>

  <!-- Ring -->
  <ellipse cx="150" cy="100" rx="50" ry="35" fill="url(#goldGrad)" stroke="#a68d28" stroke-width="1"/>
  <ellipse cx="150" cy="95" rx="35" ry="22" fill="none" stroke="#f4e8c1" stroke-width="2" opacity="0.7"/>

  <!-- Diamond stone -->
  <polygon points="150,120 160,145 150,160 140,145" fill="#e8f4f8" stroke="#a0c0d0" stroke-width="1" opacity="0.9"/>
  <polygon points="150,125 156,140 150,152 144,140" fill="#ffffff" opacity="0.6"/>

  <!-- Shine -->
  <circle cx="142" cy="105" r="6" fill="#f4e8c1" opacity="0.8"/>

  <!-- Text -->
  <text x="150" y="240" font-family="Playfair Display, serif" font-size="20" font-weight="600" text-anchor="middle" fill="#d4af37">RINGS</text>
</svg>