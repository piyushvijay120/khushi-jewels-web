<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 300 300" width="300" height="300">
  <defs>
    <linearGradient id="goldGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#f4e8c1;stop-opacity:1" />
      <stop offset="50%" style="stop-color:#d4af37;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#a68d28;stop-opacity:1" />
    </linearGradient>
  </defs>
  <rect width="300" height="300" fill="#fafaf8"/>

  <!-- Four bangles arranged -->
  <!-- Bangle 1 -->
  <ellipse cx="100" cy="100" rx="35" ry="40" fill="none" stroke="url(#goldGrad)" stroke-width="8" opacity="0.9"/>
  <ellipse cx="100" cy="100" rx="35" ry="40" fill="none" stroke="#f4e8c1" stroke-width="2" opacity="0.5"/>

  <!-- Bangle 2 -->
  <ellipse cx="150" cy="85" rx="38" ry="45" fill="none" stroke="url(#goldGrad)" stroke-width="8" opacity="0.85"/>
  <ellipse cx="150" cy="85" rx="38" ry="45" fill="none" stroke="#f4e8c1" stroke-width="2" opacity="0.4"/>

  <!-- Bangle 3 -->
  <ellipse cx="200" cy="100" rx="35" ry="40" fill="none" stroke="url(#goldGrad)" stroke-width="8" opacity="0.8"/>
  <ellipse cx="200" cy="100" rx="35" ry="40" fill="none" stroke="#f4e8c1" stroke-width="2" opacity="0.4"/>

  <!-- Bangle 4 -->
  <ellipse cx="150" cy="120" rx="40" ry="50" fill="none" stroke="url(#goldGrad)" stroke-width="8" opacity="0.75"/>
  <ellipse cx="150" cy="120" rx="40" ry="50" fill="none" stroke="#f4e8c1" stroke-width="2" opacity="0.3"/>

  <!-- Text -->
  <text x="150" y="250" font-family="Playfair Display, serif" font-size="20" font-weight="600" text-anchor="middle" fill="#d4af37">BANGLES</text>
</svg>