<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 300 300" width="300" height="300">
  <defs>
    <linearGradient id="goldGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#f4e8c1;stop-opacity:1" />
      <stop offset="50%" style="stop-color:#d4af37;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#a68d28;stop-opacity:1" />
    </linearGradient>
  </defs>
  <rect width="300" height="300" fill="#fafaf8"/>

  <!-- Left diamond earring -->
  <polygon points="80,50 95,80 80,110 65,80" fill="#b0e8ff" stroke="#5a9ab5" stroke-width="1"/>
  <polygon points="80,60 88,80 80,100 72,80" fill="#e8f8ff" opacity="0.7"/>

  <!-- Right diamond earring -->
  <polygon points="220,50 235,80 220,110 205,80" fill="#b0e8ff" stroke="#5a9ab5" stroke-width="1"/>
  <polygon points="220,60 228,80 220,100 212,80" fill="#e8f8ff" opacity="0.7"/>

  <!-- Gold settings -->
  <circle cx="80" cy="115" r="8" fill="url(#goldGrad)" stroke="#a68d28" stroke-width="1"/>
  <circle cx="220" cy="115" r="8" fill="url(#goldGrad)" stroke="#a68d28" stroke-width="1"/>

  <!-- Posts -->
  <line x1="80" y1="123" x2="80" y2="140" stroke="#d4af37" stroke-width="2"/>
  <line x1="220" y1="123" x2="220" y2="140" stroke="#d4af37" stroke-width="2"/>

  <!-- Text -->
  <text x="150" y="240" font-family="Playfair Display, serif" font-size="20" font-weight="600" text-anchor="middle" fill="#d4af37">STUDS</text>
</svg>