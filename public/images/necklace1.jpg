<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 300 350" width="300" height="350">
  <defs>
    <linearGradient id="goldGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#f4e8c1;stop-opacity:1" />
      <stop offset="50%" style="stop-color:#d4af37;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#a68d28;stop-opacity:1" />
    </linearGradient>
  </defs>
  <rect width="300" height="350" fill="#fafaf8"/>

  <!-- Chain top -->
  <line x1="150" y1="20" x2="150" y2="60" stroke="#d4af37" stroke-width="3"/>

  <!-- Pendant stone (pearl) -->
  <circle cx="150" cy="100" r="25" fill="#f0e6d2" stroke="#c9a961" stroke-width="1"/>
  <circle cx="145" cy="95" r="8" fill="#ffffff" opacity="0.6"/>

  <!-- Chain middle -->
  <g opacity="0.8">
    <circle cx="135" cy="75" r="4" fill="#d4af37"/>
    <circle cx="165" cy="75" r="4" fill="#d4af37"/>
    <circle cx="125" cy="85" r="4" fill="#d4af37"/>
    <circle cx="175" cy="85" r="4" fill="#d4af37"/>
  </g>

  <!-- Chain links -->
  <path d="M 150 130 Q 140 150 150 170 Q 160 150 150 130" fill="none" stroke="#d4af37" stroke-width="2.5" opacity="0.8"/>
  <path d="M 150 170 Q 140 190 150 210 Q 160 190 150 170" fill="none" stroke="#d4af37" stroke-width="2.5" opacity="0.8"/>

  <!-- Text -->
  <text x="150" y="280" font-family="Playfair Display, serif" font-size="20" font-weight="600" text-anchor="middle" fill="#d4af37">NECKLACE</text>
</svg>