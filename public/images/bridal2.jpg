<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 300 450" width="300" height="450">
  <defs>
    <linearGradient id="goldGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#f4e8c1;stop-opacity:1" />
      <stop offset="50%" style="stop-color:#d4af37;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#a68d28;stop-opacity:1" />
    </linearGradient>
  </defs>
  <rect width="300" height="450" fill="#fafaf8"/>

  <!-- Necklace -->
  <g>
    <line x1="100" y1="50" x2="200" y2="50" stroke="#d4af37" stroke-width="2.5"/>
    <polygon points="150,30 170,70 150,110 130,70" fill="#b0e8ff" stroke="#5a9ab5" stroke-width="1.5"/>
    <circle cx="100" cy="55" r="8" fill="url(#goldGrad)" stroke="#a68d28" stroke-width="1"/>
    <circle cx="200" cy="55" r="8" fill="url(#goldGrad)" stroke="#a68d28" stroke-width="1"/>
  </g>

  <!-- Earrings -->
  <g>
    <polygon points="80,180 92,210 80,240 68,210" fill="#b0e8ff" stroke="#5a9ab5" stroke-width="1"/>
    <circle cx="80" cy="250" r="5" fill="url(#goldGrad)"/>

    <polygon points="220,180 232,210 220,240 208,210" fill="#b0e8ff" stroke="#5a9ab5" stroke-width="1"/>
    <circle cx="220" cy="250" r="5" fill="url(#goldGrad)"/>
  </g>

  <!-- Bangles -->
  <g>
    <ellipse cx="120" cy="320" rx="25" ry="35" fill="none" stroke="url(#goldGrad)" stroke-width="8"/>
    <ellipse cx="180" cy="320" rx="25" ry="35" fill="none" stroke="url(#goldGrad)" stroke-width="8"/>
  </g>

  <!-- Text -->
  <text x="150" y="410" font-family="Playfair Display, serif" font-size="18" font-weight="600" text-anchor="middle" fill="#d4af37">WEDDING SET</text>
</svg>