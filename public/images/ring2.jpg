<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 300 300" width="300" height="300">
  <defs>
    <linearGradient id="goldGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#f4e8c1;stop-opacity:1" />
      <stop offset="50%" style="stop-color:#d4af37;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#a68d28;stop-opacity:1" />
    </linearGradient>
  </defs>
  <rect width="300" height="300" fill="#fafaf8"/>

  <!-- Ring 2 with diamond -->
  <ellipse cx="150" cy="80" rx="45" ry="32" fill="url(#goldGrad)" stroke="#a68d28" stroke-width="1"/>
  <ellipse cx="150" cy="76" rx="30" ry="20" fill="none" stroke="#f4e8c1" stroke-width="2" opacity="0.7"/>

  <!-- Large diamond -->
  <polygon points="150,105 168,135 150,165 132,135" fill="#b0e8ff" stroke="#5a9ab5" stroke-width="1"/>
  <polygon points="150,115 160,135 150,155 140,135" fill="#e8f8ff" opacity="0.8"/>

  <!-- Sparkle -->
  <circle cx="145" cy="90" r="4" fill="#f4e8c1" opacity="0.9"/>
  <circle cx="155" cy="85" r="3" fill="#ffffff" opacity="0.7"/>

  <!-- Text -->
  <text x="150" y="240" font-family="Playfair Display, serif" font-size="20" font-weight="600" text-anchor="middle" fill="#d4af37">SOLITAIRE</text>
</svg>